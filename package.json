{
  "name": "youshika",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Youshika personal full-stack blog built with Vue 3, Vite, Express, MySQL and Redis.",
  "scripts": {
    "dev": "concurrently -n web,server -c cyan,green \"vite --host 0.0.0.0\" \"tsx watch server/src/main.ts\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/src/main.ts",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "server:start": "tsx server/src/main.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.12.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vue-tsc": "^2.2.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1"
}
